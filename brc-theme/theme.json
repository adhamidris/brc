{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1180px",
      "wideSize": "1440px"
    },
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "palette": [
        {
          "slug": "ink",
          "color": "#101312",
          "name": "Ink"
        },
        {
          "slug": "charcoal",
          "color": "#1e2321",
          "name": "Charcoal"
        },
        {
          "slug": "ivory",
          "color": "#f7f4ee",
          "name": "Ivory"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "bronze",
          "color": "#b58a5c",
          "name": "Bronze"
        },
        {
          "slug": "stone",
          "color": "#d8d2c8",
          "name": "Stone"
        }
      ]
    },
    "typography": {
      "fluid": false,
      "fontFamilies": [
        {
          "slug": "system",
          "name": "System Sans",
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
        },
        {
          "slug": "serif",
          "name": "Display Serif",
          "fontFamily": "Georgia, \"Times New Roman\", serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "base",
          "size": "1rem",
          "name": "Base"
        },
        {
          "slug": "large",
          "size": "1.5rem",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "2.25rem",
          "name": "XL"
        }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "vh", "vw", "%"]
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#101312"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|system",
      "lineHeight": "1.5"
    },
    "elements": {
      "link": {
        "color": {
          "text": "#101312"
        }
      }
    }
  }
}

